#!/bin/sh
# /sbin/bash-watch — diagnostic service managed by claw.
# Simplified: no pipes, no subshells, no date/wc - just progress markers.

mkdir -p /var/log
echo "bw-step-1-mkdir-done" >> /root/bw.log

echo "bw-step-2-entering-while" >> /root/bw.log
while true; do
    echo "bw-loop" >> /root/bw.log
    sleep 5
done
